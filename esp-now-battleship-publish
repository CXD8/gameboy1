#define C_LIGHTGREY   0xC618

#define BTN_NONE        0
#define BTN_SHORT_CLICK 1
#define BTN_LONG_PRESS  2

// --- GAME LOGIC DEFINITIONS ---
enum GameState { STATE_MENU, STATE_PAIRING, STATE_PLACE_SHIPS, STATE_WAITING_OPPONENT, STATE_GAME_PLAY, STATE_GAME_OVER };
enum PlaySubState { MY_TURN, WAIT_RESULT, WAIT_TURN };
enum MsgType { MSG_PAIR_REQ, MSG_PAIR_ACK, MSG_READY, MSG_GAME_START, MSG_FIRE, MSG_FIRE_RESULT, MSG_RESET };

struct GamePacket {
  uint8_t type; 
  uint8_t x;    
  uint8_t y;    
  uint8_t result; 
  uint8_t seqNum; // Used to prevent desyncs from duplicated/dropped packets
};

struct Ship {
  uint8_t length;
  uint8_t x;
  uint8_t y;
  bool horizontal;
  bool placed;
};

// --- GLOBAL VARIABLES ---
GameState gameState = STATE_MENU;
PlaySubState playSubState = WAIT_TURN;

// Host / Client Roles
bool isHost = false;
bool isHosting = false; 

uint8_t myGrid[8][8] = {0};
uint8_t opponentGrid[8][8] = {0};

Ship myShips[3] = {
  {4, 0, 0, true, false}, // Cruiser
  {3, 0, 0, true, false}, // Destroyer
  {2, 0, 0, true, false}  // Patrol Boat
};

uint8_t currentShipToPlace = 0;
bool opponentReady = false;
int opponentShipsSunkCount = 0;
bool isWinner = false;

uint8_t placementX = 0, placementY = 0;
bool placementHorizontal = true;
uint8_t targetX = 0, targetY = 0;

// Network Synchronization Tracker
uint8_t myShotID = 1;
uint8_t lastOpponentShotID = 0;
uint8_t lastOpponentShotResult = 0;

unsigned long lastJoyMove = 0;
int joyMoveCooldown = 350; 
int moveX = 0, moveY = 0;
int centerX = 2048, centerY = 2048;
const int deadzone = 800; 

unsigned long popupEndTime = 0;
String popupText = "";
uint16_t popupColor = C_WHITE;
uint8_t opponentMAC[6] = {0};
bool peerAdded = false;
const uint8_t broadcastMAC[6] = {0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF};

unsigned long lastNetworkSend = 0;
unsigned long shotSentTime = 0;

// --- FORWARD DECLARATIONS ---
